# 服务配置
APP_ENV=dev
APP_PORT=8090

# 数据源模式: memory | mysql
# memory 模式启动即用 mock 数据，无需 MySQL，适合前端联调
DATA_SOURCE=memory

# MySQL 配置（DATA_SOURCE=mysql 时生效）
MYSQL_DSN=aimj:aimj@tcp(127.0.0.1:3306)/aimj?charset=utf8mb4&parseTime=True&loc=Local

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRE_HOURS=168

# CDN（返回视频 URL 时拼接）
CDN_BASE=https://cdn.example.com
